#!/usr/bin/env bash
set -euo pipefail

ROOT="$(cd "$(dirname "$0")/.." && pwd)"
SUPPORTED_IMAGE="${SUPPORTED_RUBY_DOCKER_IMAGE:-ruby:4.0.5-trixie}"
UNSUPPORTED_IMAGE="${UNSUPPORTED_RUBY_DOCKER_IMAGE:-ruby:4.0.5-bookworm}"
ENABLE_POLICY="RUBYGEMS_GEM_SERVER_TLS_KEY_EXCHANGE_POLICY=pq_required"

echo "== supported runtime: ${SUPPORTED_IMAGE}"
docker run --rm \
  -v "${ROOT}:/work" \
  -w /work \
  "${SUPPORTED_IMAGE}" \
  bash -lc "${ENABLE_POLICY} ruby -Ilib -rrubygems_plugin -e 'abort \"policy was not installed\" unless Gem::PqTlsPolicy.installed?; puts \"policy installed\"'"

echo "== unsupported runtime: ${UNSUPPORTED_IMAGE}"
set +e
output="$(
  docker run --rm \
    -v "${ROOT}:/work" \
    -w /work \
    "${UNSUPPORTED_IMAGE}" \
    bash -lc "${ENABLE_POLICY} ruby -Ilib -rrubygems_plugin -e 'puts \"unexpected success\"'" 2>&1
)"
status=$?
set -e

printf "%s\n" "$output"

if [[ "$status" -eq 0 ]]; then
  echo "expected unsupported runtime to fail, but it succeeded" >&2
  exit 1
fi

if ! grep -q "Gem::PqTlsPolicy::UnsupportedRuntime" <<<"$output"; then
  echo "expected UnsupportedRuntime error" >&2
  exit 1
fi

if ! grep -q "OpenSSL runtime must be 3.5.0 or newer" <<<"$output"; then
  echo "expected OpenSSL version requirement in error output" >&2
  exit 1
fi

if ! grep -q "OpenSSL::SSL::SSLSocket#group is unavailable" <<<"$output"; then
  echo "expected SSLSocket#group requirement in error output" >&2
  exit 1
fi

echo "== runtime checks complete"
